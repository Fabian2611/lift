use std::env;
use std::io::Read;
use std::process;
use std::sync::{Arc, Mutex};
use rand::distr::SampleString;
use warp::Filter;
use tokio::sync::oneshot;

fn random_path() -> String {
    rand::distr::Alphanumeric.sample_string(&mut rand::rng(), 8)
}

async fn serve(data: String) {
    let r = random_path();
    let ip = {
        let socket = std::net::UdpSocket::bind("0.0.0.0:0").unwrap();
        socket.connect("8.8.8.8:80").unwrap();
        socket.local_addr().unwrap().ip()
    };
    println!("Serving http://{}:3030/{}", ip, &r);

    let (tx, rx) = oneshot::channel::<()>();

    let tx_mx = Arc::new(Mutex::new(Some(tx)));

    let route = warp::path(r)
        .map(move || {
            if let Ok(mut guard) = tx_mx.lock() {
                if let Some(sender) = guard.take() {
                    let _ = sender.send(());
                }
            }
            data.clone()
        });

    warp::serve(route)
        .bind(([0, 0, 0, 0], 0)).await
        .graceful(async move {
            let _ = rx.await;
        }).run().await;
}

fn from_stdin() -> String {
    let mut data: String = String::new();
    std::io::stdin().read_to_string(&mut data).expect("Failed to read from stdin");
    data
}

fn from_file(path: String) -> String {
    std::fs::read_to_string(path).expect("Failed to read from file")
}

#[tokio::main]
async fn main() {
    let args: Vec<String> = env::args().collect();

    let data = match args.len() {
        1 => from_stdin(),
        2 => from_file(args[1].clone()),
        _ => {
            eprintln!("Usage: lift [filename]");
            eprintln!("If no filename is specified, read from pipe.");
            process::exit(1);
        }
    };

    serve(data).await;
}
